# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
PORT=5000

# Database (default: SQLite — change to PostgreSQL for production)
DATABASE_URL=sqlite:///sentiment.db
# DATABASE_URL=postgresql://user:password@localhost:5432/sentiment_db

# Model paths
MODEL_PATH=data/checkpoints/bert_sentiment
SARCASM_MODEL_PATH=data/checkpoints/sarcasm_model
BERT_MODEL_NAME=bert-base-uncased

# Training hyperparameters
MAX_LENGTH=256
BATCH_SIZE=16
LEARNING_RATE=2e-5
NUM_EPOCHS=3
WARMUP_STEPS=500
WEIGHT_DECAY=0.01
MAX_TRAIN_SAMPLES=60000

# Dataset splits
TRAIN_SIZE=0.8
VAL_SIZE=0.1
TEST_SIZE=0.1

# VADER thresholds
VADER_COMPOUND_POSITIVE=0.05
VADER_COMPOUND_NEGATIVE=-0.05
CONFIDENCE_THRESHOLD=0.6

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
